# ─────────────────────────────────────────────
# KarIA Escobar — Variables de entorno
# Copiá este archivo como .env y completá los valores.
# NUNCA commiteés el .env real al repositorio.
# ─────────────────────────────────────────────

# Servidor
PORT=3003
NODE_ENV=development

# Frontend (lista separada por comas para CORS)
ALLOWED_ORIGINS=http://localhost:5173

# JWT — generá un secreto fuerte (ej: openssl rand -hex 32)
JWT_SECRET=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Google OAuth2
# Creá las credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3003/api/integraciones/google/callback
