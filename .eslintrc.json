{
  "env": { "node": true, "es2021": true },
  "parserOptions": { "ecmaVersion": 2021 },
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "error",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": "error",
    "no-process-env": "error"
  },
  "overrides": [
    {
      "files": ["src/config/index.js"],
      "rules": {
        "no-process-env": "off"
      }
    }
  ]
}
